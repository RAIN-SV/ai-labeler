# ════════════════════════════════════════════════════════
#  ai-worker/.env.example  — 后端环境变量模板
#  复制为 .env 并填入真实值后启动
# ════════════════════════════════════════════════════════

# Supabase Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Service Role Key（具有写权限，保密！）
# 获取路径：Supabase 控制台 → 项目设置 → API → service_role
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# 可选：Bearer Token 访问保护（留空则不启用认证）
APP_TOKEN=

# 可选：允许的前端域名（逗号分隔，默认仅 localhost:3000）
ALLOWED_ORIGINS=http://localhost:3000

# 可选：文本截断字符上限（默认 6000）
TEXT_CHAR_LIMIT=6000
