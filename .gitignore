# ════════════════════════════════════════════════════════
#  AI Labeler — 根目录 .gitignore
# ════════════════════════════════════════════════════════

# ── 绝对不上传：密钥 & 环境配置 ──────────────────────────
.env
.env.local
.env.*.local
ai-worker/.env

# ── Python 虚拟环境 & 缓存 ────────────────────────────────
ai-worker/.venv/
ai-worker/__pycache__/
ai-worker/*.pyc
ai-worker/*.pyo
**/__pycache__/
**/*.py[cod]

# ── Node / Next.js ───────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# ── 运行日志（体积大，无价值）────────────────────────────
logs/

# ── macOS 系统文件 ────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── 临时文件 ─────────────────────────────────────────────
*.pem
*.key
tmp/
/tmp/ailabel_*
